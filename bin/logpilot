#!/usr/bin/env node
/**
 * 开发时: npm run build 后 npx logpilot
 * 或: node --import tsx bin/logpilot (若安装 tsx)
 * 发布入口为 package.json bin -> dist/cli/index.js
 */
import { fileURLToPath } from 'url';
import { dirname, join } from 'path';

const __dirname = dirname(fileURLToPath(import.meta.url));
const distCli = join(__dirname, '..', 'dist', 'cli', 'index.js');

try {
  await import(distCli);
} catch {
  console.error('请先执行 npm run build 生成 dist/cli/index.js');
  process.exit(1);
}

